# Groq API key — get one from https://console.groq.com/
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Port the server listens on (default 8787).
PORT=8787

# Optional: model id. Defaults to llama-3.3-70b-versatile.
GROQ_MODEL=llama-3.3-70b-versatile

# Optional: comma-separated CORS origins. Defaults to *.
CORS_ORIGIN=*

# ─── RAG (Phase 3) ────────────────────────────────────────────────────────────
# Supabase project. Use the **service_role** secret (Settings → API → "service_role").
# A "publishable" / anon key WILL FAIL — it can't bypass RLS for inserts during
# ingest or call the match_knowledge_chunks RPC.
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxx_or_sb_secret_xxxxx

# Gemini API for embeddings.
GEMINI_API_KEY=xxxxxxxxxxxx
# Default: gemini-embedding-001 (current production model). The older
# text-embedding-004 returns 404 for new API keys.
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
# Truncate gemini-embedding-001's native 3072-dim output to match the
# schema's vector(768) column. Set to 1536 or 3072 only if you ALSO change
# the schema and re-ingest.
GEMINI_EMBEDDING_DIM=768
